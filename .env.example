SPRING_PROFILES_ACTIVE=

# Database
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# 관리자 Telegram 알림
# BotFather에서 발급받은 토큰, getUpdates API로 chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AES-256 암호화 키 (KIS 자격증명·계좌번호 암호화)
# 생성 방법: openssl rand -base64 32
AES_ENCRYPTION_KEY=

# EC P-256 JWK JSON (private+public) — 카카오 OAuth 자체 JWT 서명·검증 키
# 생성 방법: jose 라이브러리 또는 nimbus-jose-jwt ECKey.generate(Curve.P_256)
JWT_SIGNING_KEY=

# 카카오 REST API 키 (카카오 개발자 콘솔 > 내 앱 > 앱 키)
KAKAO_CLIENT_ID=
# 카카오 앱 보안 코드 (선택 — 카카오 개발자 콘솔 > 보안에서 활성화 시 필요)
KAKAO_CLIENT_SECRET=

# CORS 허용 도메인 (프로토콜 포함, 쉼표로 구분하여 여러 개 등록 가능)
# 예: http://localhost:3000,https://kista-web.vercel.app (마지막 슬래시 제외)
CORS_ALLOWED_ORIGINS=

# ADMIN 권한 자동 부여 대상 카카오 ID 목록 (선택)
# 쉼표 구분 카카오 ID 목록, 자동 ADMIN 승격
ADMIN_KAKAO_IDS=

# Redis URL (AT 블랙리스트)
# 로컬: docker compose up -d redis 후 redis://localhost:6379 (application-local.yml에 설정)
# 운영: Upstash Console(https://console.upstash.com) → Redis 생성 → rediss://... 형식
# flyctl secrets set REDIS_URL='rediss://...' -a kista-api
REDIS_URL=

# 서버 간 내부 API 인증 토큰 (POST /api/internal/** 엔드포인트 보호)
# 생성 방법: openssl rand -hex 32
INTERNAL_API_TOKEN=

# Firebase Admin SDK 서비스 계정 JSON (한 줄 직렬화, 미설정 시 FCM 비활성화)
FIREBASE_SERVICE_ACCOUNT_JSON=

# Alpaca Markets API (미국 시장 휴장일 캘린더 조회 — paper trading 무료 계정 사용)
# 발급: https://app.alpaca.markets (Paper Trading > API Keys)
ALPACA_API_KEY=
ALPACA_API_SECRET=

# Toss 공통 API(시세·환율·캔들·시장정보) 조회용 관리자 자격증명
# 개별 계좌 무관 공용 데이터이므로 관리자 본인 계좌의 client_id/secret 사용
TOSS_ADMIN_CLIENT_ID=
TOSS_ADMIN_CLIENT_SECRET=

# healthchecks.io dead-man's switch — 개장/마감 스케쥴러 실행 완료 ping (미설정 시 핑 생략, 배포 안전)
HEARTBEAT_OPEN_URL=
HEARTBEAT_CLOSE_URL=

# Grafana Cloud OTLP 메트릭 push (미설정 시 비활성 — 로컬/테스트는 기본 false 유지)
# 발급: Grafana Cloud Console > Connections > Add new connection > OpenTelemetry (Serverless/Others)
# ENDPOINT는 콘솔이 보여주는 base URL 끝에 /v1/metrics를 붙여야 함
GRAFANA_CLOUD_OTLP_ENABLED=
GRAFANA_CLOUD_OTLP_ENDPOINT=
GRAFANA_CLOUD_OTLP_AUTH_HEADER=
