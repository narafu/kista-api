# KIS API 설정 (한국투자증권 모의투자 or 실계좌)
KIS_APP_KEY=your_app_key
KIS_APP_SECRET=your_app_secret
KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_TYPE=01
KIS_SYMBOL=SOXL
KIS_EXCHANGE_CODE=AMS

# Telegram 알림
# BotFather에서 발급받은 토큰, getUpdates API로 chat_id 확인
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=987654321

# Database (로컬)
DB_URL=jdbc:postgresql://localhost:5432/kistadb
DB_USERNAME=kista
DB_PASSWORD=kista

# Database (Supabase — prod 배포 시)
# Render 환경변수로 아래 값을 설정 (Supabase 대시보드 > Settings > Database > Connection Pooling)
# DB_URL=jdbc:postgresql://<project>.pooler.supabase.com:6543/postgres?pgbouncer=true&prepareThreshold=0
# DB_USERNAME=postgres.<project-ref>
# DB_PASSWORD=<your-password>
