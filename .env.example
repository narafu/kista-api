SPRING_PROFILES_ACTIVE=

# Database
DB_NAME=
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# 관리자 Telegram 알림
# BotFather에서 발급받은 토큰, getUpdates API로 chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AES-256 암호화 키 (KIS 자격증명·계좌번호 암호화)
# 생성 방법: openssl rand -base64 32
AES_ENCRYPTION_KEY=

# 운영 ECC P-256 JWKS 검증 URI (로컬에서는 jwt-secret 사용)
# Supabase JWKS URI (ECC P-256 JWT 검증 — Settings > JWT Keys에서 project-ref 확인)
# 형식: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URI=

# CORS 허용 도메인 (프로토콜 포함, 쉼표로 구분하여 여러 개 등록 가능)
# 예: http://localhost:3000,https://kista-web.vercel.app (마지막 슬래시 제외)
CORS_ALLOWED_ORIGINS=