SPRING_PROFILES_ACTIVE=

# Database
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# 관리자 Telegram 알림
# BotFather에서 발급받은 토큰, getUpdates API로 chat_id 확인
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AES-256 암호화 키 (KIS 자격증명·계좌번호 암호화)
# 생성 방법: openssl rand -base64 32
AES_ENCRYPTION_KEY=

# EC P-256 JWK JSON (private+public) — 카카오 OAuth 자체 JWT 서명·검증 키
# 생성 방법: jose 라이브러리 또는 nimbus-jose-jwt ECKey.generate(Curve.P_256)
JWT_SIGNING_KEY=

# 카카오 REST API 키 (카카오 개발자 콘솔 > 내 앱 > 앱 키)
KAKAO_CLIENT_ID=
# 카카오 앱 보안 코드 (선택 — 카카오 개발자 콘솔 > 보안에서 활성화 시 필요)
KAKAO_CLIENT_SECRET=

# CORS 허용 도메인 (프로토콜 포함, 쉼표로 구분하여 여러 개 등록 가능)
# 예: http://localhost:3000,https://kista-web.vercel.app (마지막 슬래시 제외)
CORS_ALLOWED_ORIGINS=