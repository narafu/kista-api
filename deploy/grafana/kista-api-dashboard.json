{
  "title": "kista-api 운영 대시보드",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "Asia/Seoul",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "panels": [
    {
      "id": 1,
      "title": "JVM 메모리 사용량 (Heap)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "grafanacloud-bouncystream2108-prom",
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "jvm_memory_used_bytes{application=\"kista-api\", area=\"heap\"}",
          "legendFormat": "{{id}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "DB 커넥션 풀 (HikariCP)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "grafanacloud-bouncystream2108-prom",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "hikaricp_connections_active{application=\"kista-api\"}",
          "legendFormat": "active"
        },
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "hikaricp_connections_idle{application=\"kista-api\"}",
          "legendFormat": "idle"
        },
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "hikaricp_connections_pending{application=\"kista-api\"}",
          "legendFormat": "pending (대기중 — 계속 0보다 크면 커넥션 부족)"
        }
      ]
    },
    {
      "id": 3,
      "title": "디스크 여유공간",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": "grafanacloud-bouncystream2108-prom",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "green", "value": 0.4 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "disk_free_bytes{application=\"kista-api\"} / disk_total_bytes{application=\"kista-api\"}",
          "legendFormat": "free ratio"
        }
      ]
    },
    {
      "id": 4,
      "title": "프로세스 업타임 (마지막 재시작 이후)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": "grafanacloud-bouncystream2108-prom",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "process_uptime_milliseconds{application=\"kista-api\"}",
          "legendFormat": "uptime"
        }
      ]
    },
    {
      "id": 5,
      "title": "CPU 사용률",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 8 },
      "datasource": "grafanacloud-bouncystream2108-prom",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "process_cpu_usage{application=\"kista-api\"}",
          "legendFormat": "cpu"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC 일시정지 시간 (5분 평균)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "datasource": "grafanacloud-bouncystream2108-prom",
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "rate(jvm_gc_pause_milliseconds_sum{application=\"kista-api\"}[5m])",
          "legendFormat": "{{action}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "HTTP 에러율 (4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": "grafanacloud-bouncystream2108-prom",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "sum by (status, uri) (rate(http_server_requests_milliseconds_count{application=\"kista-api\", outcome=~\"CLIENT_ERROR|SERVER_ERROR\"}[5m]))",
          "legendFormat": "{{status}} {{uri}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "에러 로그 발생 건수 (5분당)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": "grafanacloud-bouncystream2108-prom",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "sum(rate(logback_events_total{application=\"kista-api\", level=\"error\"}[5m]))",
          "legendFormat": "error"
        },
        {
          "datasource": "grafanacloud-bouncystream2108-prom",
          "expr": "sum(rate(logback_events_total{application=\"kista-api\", level=\"warn\"}[5m]))",
          "legendFormat": "warn"
        }
      ]
    }
  ]
}
