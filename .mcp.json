{
  "mcpServers": {
    "shrimp-task-manager": {
      "type": "stdio",
      "command": "sh",
      "args": ["-c", "DATA_DIR=${HOME}/workspace/kista/.shrimp-data node ${HOME}/workspace/mcp-shrimp-task-manager/dist/index.js"],
      "env": {
        "TEMPLATES_USE": "en"
      }
    },
    "kis-coding-mcp": {
      "type": "http",
      "url": "http://localhost:8081/mcp"
    },
    "render": {
      "type": "stdio",
      "command": "sh",
      "args": ["-c", "npx mcp-remote https://mcp.render.com/mcp --header \"Authorization: Bearer ${RENDER_API_KEY}\""]
    }
  }
}