{
  "mcpServers": {
    "shrimp-task-manager": {
      "type": "stdio",
      "command": "sh",
      "args": ["-c", "node ${HOME}/workspace/mcp-shrimp-task-manager/dist/index.js"],
      "env": {
        "DATA_DIR": "/home/user/workspace/kista/.shrimp-data",
        "TEMPLATES_USE": "en"
      }
    },
    "kis-coding-mcp": {
      "type": "http",
      "url": "http://localhost:8081/mcp"
    }
  }
}
