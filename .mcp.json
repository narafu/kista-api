{
  "mcpServers": {
    "shrimp-task-manager": {
      "type": "stdio",
      "command": "node",
      "args": ["D:/src/mcp/mcp-shrimp-task-manager/dist/index.js"],
      "env": {
        "DATA_DIR": "D:/src/study/kista/.shrimp-data",
        "TEMPLATES_USE": "en"
      }
    },
    "render": {
      "type": "stdio",
      "command": "sh",
      "args": [
        "-c",
        "npx mcp-remote https://mcp.render.com/mcp --header \"Authorization: Bearer ${RENDER_API_KEY}\""
      ]
    },
    "kis-coding-mcp": {
      "type": "http",
      "url": "http://localhost:8081/mcp"
    },
    "kis-trade-mcp": {
      "type": "sse",
      "url": "http://localhost:3001/sse"
    }
  }
}
