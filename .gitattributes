# 모든 텍스트 파일 LF로 정규화
* text=auto eol=lf

# 명시적 LF 강제
*.java   text eol=lf
*.kt     text eol=lf
*.kts    text eol=lf
*.sql    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.properties text eol=lf
*.toml   text eol=lf
*.sh     text eol=lf

# 바이너리 파일은 변환 제외
*.jar    binary
*.class  binary
*.png    binary
*.jpg    binary
